# Primera vez / si el scan dice "Could not find Chrome": npm run puppeteer:install
# (también corre en postinstall de npm install; hace falta red la primera vez)

# Opcional: si está definida, el scan usa OpenAI para matchear ofertas con tu CV.
OPENAI_API_KEY=
# Por defecto gpt-4o-mini
OPENAI_MODEL=gpt-4o-mini

# Chrome (Puppeteer): siempre sin ventana (headless). Cuántas URLs a la vez (default 2, máx 8)
# JOBSP_CONCURRENCY=2
# Prueba corta: solo las primeras N empresas (ej. 3)
# JOBSP_MAX_COMPANIES=3
# Opcional: Chrome instalado en vez del Chromium empaquetado
# JOBSP_CHROME_CHANNEL=chrome
# Ruta explícita al ejecutable
# PUPPETEER_EXECUTABLE_PATH=
# JOBSP_NAV_TIMEOUT_MS=45000
# Espera extra tras load (SPAs), ms
# JOBSP_POST_WAIT_MS=2500
